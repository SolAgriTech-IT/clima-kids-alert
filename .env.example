# =============================================================================
# CLIMA-KIDS ALERT — environment template (copy to .env before docker compose)
# =============================================================================

# PostgreSQL / PostGIS (defaults match docker-compose service names)
POSTGRES_USER=clima
POSTGRES_PASSWORD=clima_secret_change_me
POSTGRES_DB=clima_kids
DATABASE_URL=postgresql+psycopg2://clima:clima_secret_change_me@db:5432/clima_kids

# Redis
REDIS_URL=redis://redis:6379/0

# App mutualisé sans Redis/Celery (voir copie ../App2 ; hébergeur type O2S) : mettre false
USE_REDIS=true
USE_CELERY=true
# Répertoire absolu du build Next.js ``output: export`` (dossier ``out``) pour servir l’UI via FastAPI
# STATIC_SITE_DIR=

# SlowAPI / shared rate limits (set for multi-replica API deployments)
# Use a different DB index than Celery (which should stay on /0).
RATE_LIMIT_STORAGE_URI=redis://redis:6379/1

# JWT — MUST be a long random string in production
JWT_SECRET=change_me_to_a_long_random_secret_minimum_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS (comma-separated origins; nginx URL in Docker)
CORS_ORIGINS=http://localhost,http://localhost:80,http://127.0.0.1

# Rate limiting (requests per minute per IP for public routes)
RATE_LIMIT_PER_MINUTE=120

# OpenWeatherMap (optional — improves multi-source weather)
OPENWEATHERMAP_API_KEY=

# OpenAQ (optional — higher quotas with token)
OPENAQ_API_KEY=

# NASA POWER — no key required for public API
NASA_POWER_ENABLED=true

# Twilio (SMS + WhatsApp) — optional; notifications log as pending if unset
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# SendGrid — optional; email skipped if unset
SENDGRID_API_KEY=
EMAIL_FROM=noreply@sol-agri-tech.org

# Kolwezi default bbox / center (lat, lon)
DEFAULT_CITY_NAME=Kolwezi
DEFAULT_CITY_SLUG=kolwezi
DEFAULT_LAT=-10.7147
DEFAULT_LON=25.4667

# MVP test contact (seeded admin; also used for manual test sends)
SEED_ADMIN_EMAIL=mulombodi@sol-agri-tech.org
SEED_ADMIN_PASSWORD=ChangeMeAfterFirstLogin!2026
# Dev/recovery: set to true once to re-hash SEED_ADMIN_PASSWORD for the seed admin (e.g. after bcrypt upgrades).
SEED_RESET_ADMIN_PASSWORD=false

# Celery beat interval override (seconds) — default 300 in code
PIPELINE_INTERVAL_SECONDS=300

# Sentinel Hub (optional) — OAuth client credentials from Copernicus Data Space / Sentinel Hub dashboard
SENTINEL_HUB_ENABLED=false
SENTINEL_HUB_BASE_URL=https://services.sentinel-hub.com
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=

# Google Earth Engine bridge (optional) — internal HTTPS service returning JSON summaries
GEE_BRIDGE_URL=
GEE_BRIDGE_TOKEN=
